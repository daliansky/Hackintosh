  #     # #     # #     # #     #      #  #     # #     #  #   #   #           #
  ######   #####  #     #  #####       #   #####   #####    ###   #######      #
            </pre>
            <h1>Hackintosh 系统报告</h1>
            <p>BCM94360Z4 驱动信息检测</p>
        </div>
        <div class="grid">
HTMLHEADER

# 系统信息卡片
cat >> "$OUTPUT_FILE" << EOF
        <div class="card">
            <h2><span class="icon">💻</span> 系统信息</h2>
            <div class="info-row">
                <span class="info-label">操作系统</span>
                <span class="info-value">$os_name $os_ver</span>
            </div>
            <div class="info-row">
                <span class="info-label">构建版本</span>
                <span class="info-value">$build_ver</span>
            </div>
            <div class="info-row">
                <span class="info-label">引导参数</span>
                <span class="info-value" style="font-size:0.85em;word-break:break-all;">$bootargs</span>
            </div>
        </div>

        <div class="card">
            <h2><span class="icon">🔧</span> 硬件信息</h2>
            <div class="info-row">
                <span class="info-label">主板型号</span>
                <span class="info-value">$board</span>
            </div>
            <div class="info-row">
                <span class="info-label">芯片组</span>
                <span class="info-value">$chipset</span>
            </div>
            <div class="info-row">
                <span class="info-label">处理器</span>
                <span class="info-value" style="font-size:0.9em;">$cpu_brand</span>
            </div>
            <div class="info-row">
                <span class="info-label">核心数</span>
                <span class="info-value">$cpu_cores</span>
            </div>
            <div class="info-row">
                <span class="info-label">频率</span>
                <span class="info-value">${freq_ghz}GHz</span>
            </div>
            <div class="info-row">
                <span class="info-label">内存</span>
                <span class="info-value">${mem_gb} GB</span>
            </div>
EOF

if [ -n "$mem_slots" ]; then
    echo '            <div style="margin-top:15px; padding-top:15px; border-top:1px solid rgba(255,255,255,0.05);">' >> "$OUTPUT_FILE"
    echo '                <div style="color:#888; font-size:0.9em; margin-bottom:10px;">内存插槽详情：</div>' >> "$OUTPUT_FILE"
    IFS=$'\n'
    for line in $mem_slots; do
        slot=$(echo "$line" | cut -d'|' -f1)
        size=$(echo "$line" | cut -d'|' -f2)
        type=$(echo "$line" | cut -d'|' -f3)
        speed=$(echo "$line" | cut -d'|' -f4)
        manuf=$(echo "$line" | cut -d'|' -f5)
        part=$(echo "$line" | cut -d'|' -f6)
        echo "                <div style=\"padding:6px 0; border-bottom:1px solid rgba(255,255,255,0.03); font-size:0.9em;\">${slot}: ${size} GB ${type} @ ${speed} - ${manuf} (${part})</div>" >> "$OUTPUT_FILE"
    done
    unset IFS
    echo '            </div>' >> "$OUTPUT_FILE"
fi

cat >> "$OUTPUT_FILE" << 'EOF'
        </div>
EOF

# WiFi卡片
cat >> "$OUTPUT_FILE" << EOF
        <div class="card">
            <h2><span class="icon">📶</span> WiFi 网卡</h2>
EOF

if [ "$wifi_is_broadcom" = true ]; then
    cat >> "$OUTPUT_FILE" << EOF
            <div class="info-row">
                <span class="info-label">芯片型号</span>
                <span class="info-value">$wifi_chip</span>
            </div>
            <div class="info-row">
                <span class="info-label">网卡类型</span>
                <span class="info-value">$wifi_type</span>
            </div>
            <div class="info-row">
                <span class="info-label">MAC地址</span>
                <span class="info-value">$wifi_mac</span>
            </div>
            <div class="info-row">
                <span class="info-label">国家码</span>
                <span class="info-value">$wifi_country</span>
            </div>
            <div class="info-row">
                <span class="info-label">状态</span>
                <span class="info-value">
EOF
    if [ "$wifi_status" = "Off" ]; then
        echo '                    <span class=\"status-badge status-warning\">已关闭</span>' >> "$OUTPUT_FILE"
    else
        echo '                    <span class=\"status-badge status-ok\">已连接</span>' >> "$OUTPUT_FILE"
    fi
    cat >> "$OUTPUT_FILE" << EOF
                </span>
            </div>
EOF
    if [ -n "$wifi_ssid" ]; then
        cat >> "$OUTPUT_FILE" << EOF
            <div class="info-row">
                <span class="info-label">SSID</span>
                <span class="info-value">$wifi_ssid</span>
            </div>
            <div class="info-row">
                <span class="info-label">频道</span>
                <span class="info-value">$wifi_channel</span>
            </div>
            <div class="info-row">
                <span class="info-label">TX速率</span>
                <span class="info-value">${wifi_txrate} Mbps</span>
            </div>
            <div class="info-row">
                <span class="info-label">RSSI</span>
                <span class="info-value">${wifi_rssi} dBm</span>
            </div>
            <div class="info-row">
                <span class="info-label">协议</span>
                <span class="info-value">$wifi_phy</span>
            </div>
            <div class="info-row">
                <span class="info-label">MCS Index</span>
                <span class="info-value">$wifi_mcs</span>
            </div>
EOF
    fi
else
    cat >> "$OUTPUT_FILE" << EOF
            <div class="info-row">
                <span class="info-label">网卡状态</span>
                <span class="info-value">
                    <span class="status-badge status-error">非博通网卡</span>
                </span>
            </div>
            <div style="padding:15px; background:rgba(231,76,60,0.1); border-radius:10px; margin-top:10px;">
                <p style="color:#e74c3c; font-size:0.9em; margin-bottom:8px;">✗ 未检测到博通WiFi网卡</p>
                <p style="color:#f1c40f; font-size:0.85em; line-height:1.5;">当前无线网卡不支持苹果隔空接力(Handoff/Continuity)功能。</p>
                <p style="color:#888; font-size:0.85em; margin-top:8px;">建议：如需完整隔空接力功能，请更换为BCM94360系列等博通芯片网卡。</p>
            </div>
EOF
fi
echo "        </div>" >> "$OUTPUT_FILE"

# 蓝牙卡片
cat >> "$OUTPUT_FILE" << EOF
        <div class="card">
            <h2><span class="icon">🔵</span> 蓝牙</h2>
            <div class="info-row">
                <span class="info-label">芯片型号</span>
                <span class="info-value">$bt_chip</span>
            </div>
            <div class="info-row">
                <span class="info-label">固件版本</span>
                <span class="info-value">$bt_firmware</span>
            </div>
            <div class="info-row">
                <span class="info-label">BLE支持</span>
                <span class="info-value">
                    <span class="status-badge status-ok">支持</span>
                </span>
            </div>
        </div>
EOF

# SMBIOS卡片
cat >> "$OUTPUT_FILE" << EOF
        <div class="card">
            <h2><span class="icon">🔐</span> SMBIOS 配置</h2>
            <div class="info-row">
                <span class="info-label">序列号</span>
                <span class="info-value" style="font-size:0.9em;">$serial</span>
            </div>
            <div class="info-row">
                <span class="info-label">系统UUID</span>
                <span class="info-value" style="font-size:0.85em;">$uuid</span>
            </div>
            <div class="info-row">
                <span class="info-label">OpenCore</span>
                <span class="info-value">$oc_ver</span>
            </div>
        </div>
EOF

# 网络接口卡片
cat >> "$OUTPUT_FILE" << EOF
        <div class="card">
            <h2><span class="icon">🌐</span> 网络接口</h2>
            <div class="info-row">
                <span class="info-label">WiFi接口</span>
                <span class="info-value">
                    $wifi_interface
EOF

if [ "$wifi_interface" = "en0" ]; then
    echo "                    <span class=\"status-badge status-ok\">✓ en0</span>" >> "$OUTPUT_FILE"
else

            border: 1px solid rgba(255,255,255,0.1);
            transition: transform 0.3s, box-shadow 0.3s;
        }
        .card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 40px rgba(0,0,0,0.3);
        }
        .card h2 {
            font-size: 1.3em;
            margin-bottom: 20px;
            padding-bottom: 10px;
            border-bottom: 2px solid rgba(255,255,255,0.1);
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .card h2 .icon { font-size: 1.5em; }
        .info-row {
            display: flex;
            justify-content: space-between;
            padding: 8px 0;
            border-bottom: 1px solid rgba(255,255,255,0.05);
        }
        .info-row:last-child { border-bottom: none; }
        .info-label { color: #888; }
        .info-value { font-weight: 500; text-align: right; max-width: 60%; }
        .status-badge {
            display: inline-block;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 0.85em;
            font-weight: 500;
        }
        .status-ok { background: rgba(46, 204, 113, 0.2); color: #2ecc71; }
        .status-warning { background: rgba(241, 196, 15, 0.2); color: #f1c40f; }
        .status-error { background: rgba(231, 76, 60, 0.2); color: #e74c3c; }
        .status-info { background: rgba(52, 152, 219, 0.2); color: #3498db; }
        .full-width { grid-column: 1 / -1; }
        .ascii-art {
            font-family: 'Courier New', 'Monaco', 'Menlo', monospace;
            font-size: 0.55em;
            line-height: 1.1;
            color: #3a7bd5;
            text-align: left;
            margin: 0 auto 20px;
            display: inline-block;
        }
        @media (max-width: 768px) {
            .grid { grid-template-columns: 1fr; }
            .header h1 { font-size: 1.8em; }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <pre class="ascii-art">
  ######   #####  #     #  #####  #        #####   #####    ###   ####### #
  #     # #     # ##   ## #     # #    #  #     # #     #  #   #       #  #    #
  #     # #       # # # # #     # #    #        # #       # #   #     #   #    #

#!/bin/sh
# 
# @desc [BCM94360Z4 Web Report Generator]
# @author [DalianSky]
# @email [daliansky2008@mail.com]
# @create date 2024-01-18
# 
# ============================================================================
# 脚本说明 / Script Description
# ============================================================================
#
# 功能 / Features:
#   - 收集 Hackintosh 系统硬件和驱动信息
#   - 生成美观的 HTML 格式报告
#   - 支持浏览器直接打开或启动 Web 服务器
#
# 用法 / Usage:
#
#   1. 直接用浏览器打开（推荐，无需服务器）:
#      sh BCM94360Z4_Web
#      sh BCM94360Z4_Web --open
#
#   2. 启动 Web 服务器（默认端口 8080）:
#      sh BCM94360Z4_Web --server
#      sh BCM94360Z4_Web -s
#
#   3. 指定端口启动服务器（避免端口冲突）:
#      sh BCM94360Z4_Web --server --port 9090
#      sh BCM94360Z4_Web -s -p 9090
#
#   4. 查看帮助:
#      sh BCM94360Z4_Web --help
#      sh BCM94360Z4_Web -h
#
#   5. 远程调用（GitHub）:
#      sh -c "$(curl -fsSL https://raw.githubusercontent.com/daliansky/Hackintosh/master/Tools/BCM94360Z4_Web)"
#
#   6. 远程调用（国内加速）:
#      sh -c "$(curl -fsSL https://ghfast.top/https://raw.githubusercontent.com/daliansky/Hackintosh/master/Tools/BCM94360Z4_Web)"
#      sh -c "$(curl -fsSL https://cdn.jsdelivr.net/gh/daliansky/Hackintosh/Tools/BCM94360Z4_Web)"
#
# 输出文件 / Output:
#   HTML报告: /tmp/hackintosh_report.html
#   可保存到任意位置，双击即可用浏览器打开
#
# 依赖 / Dependencies:
#   - macOS 系统
#   - Python 3（仅 --server 模式需要）
#   - 网络连接（用于收集系统信息）
#
# 端口说明 / Port Notes:
#   - 默认端口: 8080
#   - 如端口被占用，使用 --port 参数指定其他端口
#   - 常见冲突端口: 3000(React), 5000(Flask), 8000(Django)
#
# ============================================================================

# 解析参数
MODE="open"
PORT=""

while [ $# -gt 0 ]; do
    case "$1" in
        --server|-s)
            MODE="server"
            shift
            ;;
        --port|-p)
            PORT="$2"
            shift 2
            ;;
        --help|-h)
            echo "用法: sh BCM94360Z4_Web [选项]"
            echo ""
            echo "选项:"
            echo "  无参数        生成HTML并用浏览器打开（推荐）"
            echo "  --server, -s  启动Web服务器"
            echo "  --port, -p    指定端口号（配合--server使用，默认8080）"
            echo "  --help, -h    显示帮助"
            exit 0
            ;;
        *)
            echo "未知参数: $1"
            exit 1
            ;;
    esac
done

# 如果没有指定端口，使用默认端口
if [ -z "$PORT" ]; then
    PORT=8080
fi

OUTPUT_FILE="/tmp/hackintosh_report.html"

# 收集系统信息
os_ver=$(sw_vers -productVersion 2>/dev/null)
os_name=$(sw_vers -productName 2>/dev/null)
build_ver=$(sw_vers -buildVersion 2>/dev/null)
bootargs=$(ioreg -l | grep -y boot-args | awk '{for(i=4;i<=NF;i++){to=to" "$i};print to}')

# 主板
board=$(sysctl -n hw.model 2>/dev/null)
if [ -z "$board" ]; then
    board=$(ioreg -l | grep -y "board-id" | head -1 | sed "s/.*=//g" | sed 's/"//g' | sed 's/ //g')
fi

# 芯片组
cpu_model=$(sysctl -n machdep.cpu.brand_string 2>/dev/null)
if echo "$cpu_model" | grep -qi "Ultra 9\|Ultra 7\|Ultra 5"; then
    chipset="Intel 800系列 (Z890/B860/H870)"
elif echo "$cpu_model" | grep -qi "i9-14\|i7-14\|i5-14\|i3-14"; then
    chipset="Intel 700系列 (B760/Z790/H770)"
elif echo "$cpu_model" | grep -qi "i9-13\|i7-13\|i5-13\|i3-13"; then
    chipset="Intel 700系列 (B760/Z790/H770)"
elif echo "$cpu_model" | grep -qi "i9-12\|i7-12\|i5-12\|i3-12"; then
    chipset="Intel 600系列 (B660/Z690/H670)"
elif echo "$cpu_model" | grep -qi "i9-11\|i7-11\|i5-11\|i3-11"; then
    chipset="Intel 500系列 (B560/Z590/H570)"
elif echo "$cpu_model" | grep -qi "i9-10\|i7-10\|i5-10\|i3-10"; then
    chipset="Intel 400系列 (B460/Z490/H470)"
elif echo "$cpu_model" | grep -qi "i9-9\|i7-9\|i5-9\|i3-9"; then
    chipset="Intel 300系列 (B360/Z390/H370)"
elif echo "$cpu_model" | grep -qi "Xeon"; then
    chipset="服务器/工作站芯片组"
else
    chipset="无法自动检测"
fi

# 内存插槽
mem_slots=$(system_profiler SPMemoryDataType 2>/dev/null | awk '
/BANK [0-9]/ { 
    if (size != "" && size != "Empty") {
        printf "%s|%s|%s|%s|%s|%s\n", slot, size, type, speed, manuf, part
    }
    slot = $0; gsub(/^[[:space:]]+/, "", slot); gsub(/:$/, "", slot)
    size=""; type=""; speed=""; manuf=""; part=""
}
/^[[:space:]]*Size:/ { size = $2 }
/^[[:space:]]*Type:/ { type = $2 }
/^[[:space:]]*Speed:/ { speed = $0; sub(/.*Speed:[[:space:]]*/, "", speed) }
/^[[:space:]]*Manufacturer:/ { manuf = $0; sub(/.*Manufacturer:[[:space:]]*/, "", manuf) }
/^[[:space:]]*Part Number:/ { part = $0; sub(/.*Part Number:[[:space:]]*/, "", part) }
END {
    if (size != "" && size != "Empty") {
        printf "%s|%s|%s|%s|%s|%s", slot, size, type, speed, manuf, part
    }
}')

# CPU
cpu_brand=$cpu_model
cpu_cores=$(sysctl -n hw.ncpu 2>/dev/null)
cpu_freq=$(sysctl -n hw.cpufrequency 2>/dev/null)
if [ -n "$cpu_freq" ]; then
    freq_ghz=$(echo "scale=2; $cpu_freq / 1000000000" | bc 2>/dev/null)
fi

# 内存
mem_size=$(sysctl -n hw.memsize 2>/dev/null)
if [ -n "$mem_size" ]; then
    mem_gb=$(echo "scale=2; $mem_size / 1073741824" | bc 2>/dev/null)
fi

# SMBIOS
serial=$(ioreg -l | grep -y "IOPlatformSerialNumber" | head -1 | sed "s/|//g" | sed 's/ //g' | sed 's/"//g' | sed 's/IOPlatformSerialNumber=//g')
uuid=$(ioreg -l | grep -y "IOPlatformUUID" | head -1 | sed "s/|//g" | sed 's/ //g' | sed 's/"//g' | sed 's/IOPlatformUUID=//g')
oc_ver=$(nvram 4D1FDA02-38C7-4A6A-9CC6-4BCCA8B30102:opencore-version 2>/dev/null | awk '{print $2}')

# WiFi
is_broadcom=$(ioreg -l | grep -y "14e4,43" | head -1)
if [ -n "$is_broadcom" ]; then
    wifi_chip=$(ioreg -l | grep -y "14e4,43" | grep "compatible" | head -1 | sed "s/.*=//g" | sed 's/"//g' | sed 's/ //g')
    wifi_mac=$(system_profiler SPAirPortDataType 2>/dev/null | grep "MAC Address" | head -1 | sed 's/.*: //g')
    wifi_detail=$(system_profiler SPAirPortDataType 2>/dev/null)
    wifi_status=$(echo "$wifi_detail" | grep "Status:" | head -1 | sed 's/.*: //g' | sed 's/^ *//g')
    wifi_type=$(system_profiler SPAirPortDataType 2>/dev/null | grep "Card Type" | head -1 | sed 's/.*: //g')
    wifi_country=$(ioreg -l | grep "IO80211CountryCode" | head -1 | sed "s/.*=//g" | sed 's/"//g' | sed 's/ //g')
    wifi_is_broadcom=true
else
    wifi_is_broadcom=false
fi

if [ "$wifi_is_broadcom" = true ] && [ "$wifi_status" != "Off" ]; then
    current_wifi=$(echo "$wifi_detail" | grep -A 10 "Current Network Information:" | head -15)
    wifi_ssid=$(echo "$wifi_detail" | grep -A 5 "Current Network Information:" | grep -v "Current Network Information:" | head -1 | sed 's/://g' | sed 's/^ *//g' | sed 's/^[[:space:]]*//')
    wifi_channel=$(echo "$current_wifi" | grep "Channel:" | head -1 | sed 's/.*: //g' | sed 's/^ *//g')
    wifi_txrate=$(echo "$current_wifi" | grep "Transmit Rate:" | head -1 | sed 's/.*: //g' | sed 's/^ *//g')
    wifi_signal=$(echo "$current_wifi" | grep "Signal / Noise:" | head -1 | sed 's/.*: //g' | sed 's/^ *//g')
    wifi_rssi=$(echo "$wifi_signal" | awk -F'/' '{print $1}' | sed 's/ dBm//g' | sed 's/^ *//g')
    wifi_mcs=$(echo "$current_wifi" | grep "MCS Index:" | head -1 | sed 's/.*: //g' | sed 's/^ *//g')
    wifi_phy=$(echo "$current_wifi" | grep "PHY Mode:" | head -1 | sed 's/.*: //g' | sed 's/^ *//g')
    wifi_nettype=$(echo "$current_wifi" | grep "Network Type:" | head -1 | sed 's/.*: //g' | sed 's/^ *//g')
    wifi_security=$(echo "$current_wifi" | grep "Security:" | head -1 | sed 's/.*: //g' | sed 's/^ *//g')
fi

# 蓝牙
bt_chip=$(system_profiler SPBluetoothDataType 2>/dev/null | grep -i "chipset" | head -1 | sed 's/.*: //g')
bt_firmware=$(ioreg -l | grep "FirmwareVersionString" | head -1 | sed "s/.*=//g" | sed 's/"//g' | sed 's/ //g')

# 网络接口
wifi_interface=$(networksetup -listallhardwareports 2>/dev/null | grep -A 1 "Wi-Fi" | grep "Device" | awk '{print $2}')
awdl_status=$(ifconfig awdl0 2>/dev/null | grep "status:" | awk '{print $2}')

# iCloud
icloud_account=$(defaults read MobileMeAccounts 2>/dev/null | grep -A 1 "AccountID" | head -1 | sed 's/.*=//g' | sed 's/;//g' | sed 's/"//g' | sed 's/^ *//g')

# Handoff
handoff_status=$(defaults read com.apple.coreservices.useractivityd 2>/dev/null | head -5)
handoff_proc=$(pgrep -x useractivityd 2>/dev/null)

# 生成HTML
cat > "$OUTPUT_FILE" << 'HTMLHEADER'
<!DOCTYPE html>
<html lang="zh-CN">
<head>
